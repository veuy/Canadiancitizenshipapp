        <item name="colorPrimary">@color/canadian_red</item>
        <item name="colorPrimaryVariant">@color/canadian_red</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/canadian_red</item>
        <item name="colorSecondaryVariant">@color/canadian_red</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar color. -->
